{
    "liveServer.settings.port": 5501,

    "[html][css][scss]": {
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.detectIndentation": false,
        "editor.formatOnSave": false,
        "editor.indentSize": 2,
        "editor.rulers": [80],
        "editor.tabSize": 2,
    },
    "[javascript]": {
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.detectIndentation": false,
        "editor.indentSize": 4,
        "editor.rulers": [80],
        "editor.tabSize": 4,
        "editor.wordBasedSuggestions": "off",
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.detectIndentation": false,
        "editor.indentSize": 2,
        "editor.rulers": [80],
        "editor.tabSize": 2,
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "containers.containerClient": "com.microsoft.visualstudio.containers.docker",
    "editor.acceptSuggestionOnEnter": "off",
    "editor.detectIndentation": true,
    "editor.fontFamily": "Hack Nerd Font Mono",
    "editor.fontSize": 14,
    "editor.fontWeight": "500",
    "editor.formatOnPaste": false,
    "editor.formatOnSave": false,
    "editor.formatOnType": false,
    "editor.guides.bracketPairs": false,
    "editor.guides.highlightActiveBracketPair": false,
    "editor.guides.highlightActiveIndentation": true,
    "editor.guides.indentation": true,
    "editor.insertSpaces": true,
    "editor.lineNumbers": "relative",
    "editor.minimap.enabled": false,
    "editor.rulers": [80],
    "editor.stickyScroll.enabled": false,
    "editor.wordWrap": "on",
    "emmet.includeLanguages": {
        "javascript": "javascriptreact",
    },
    "files.autoSave": "off",
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "never",
    "github.copilot.enable": {
        "*": false,
        "css": false,
        "html": false,
        "javascript": false,
        "markdown": false,
        "plaintext": false,
        "scminput": false,
    },
    "github.copilot.nextEditSuggestions.enabled": false,
    "liveSassCompile.settings.compileOnWatch": false,
    "liveSassCompile.settings.formats": [
        {
            "extensionName": ".css",
            "format": "expanded",
            "savePath": null,
            "savePathReplacementPairs": null,
        },
        {
            "extensionName": "-min.css",
            "format": "compressed",
            "generateMap": false,
            "savePath": null,
            "savePathReplacementPairs": null,
        },
    ],
    "liveSassCompile.settings.showOutputWindowOn": "Warning",
    "liveSassCompile.settings.useNewCompiler": true,
    "liveServer.settings.CustomBrowser": "firefox",
    "liveServer.settings.donotShowInfoMsg": true,
    "liveServer.settings.donotVerifyTags": true,
    "markdown.preview.fontSize": 13,
    "mdb.mcp.server": "autoStartDisabled",
    "prettier.tabWidth": 4,
    "terminal.integrated.fontFamily": "monospace",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.shellIntegration.environmentReporting": true,
    "terminal.integrated.tabs.title": "${shellpromptInput}",
    "vim.easymotion": true,
    "vim.handleKeys": {
        "/": true,
        "<C-d>": true,
        "<C-r>": true,
        "<C-s>": true,
        "<C-z>": true,
        "<Shift-Up>": true,
    },
    "vim.leader": "'",
    "vim.smartRelativeLine": true,
    "vim.statusBarColorControl": false,
    "vim.useCtrlKeys": true,
    "vim.useSystemClipboard": true,
    "vim.vimrc.enable": true,
    "vim.vimrc.path": "$HOME/.vimrc",
    "workbench.colorCustomizations": {
        "[Material Theme Palenight]": {
            "activityBar.activeBorder": "#7CB342",
            "activityBarBadge.background": "#7CB342",
            "breadcrumb.activeSelectionForeground": "#7CB342",
            "editor.findMatchBorder": "#7CB342",
            "editorSuggestWidget.highlightForeground": "#7CB342",
            "editorWidget.border": "#7CB342",
            "editorWidget.resizeBorder": "#7CB342",
            "list.activeSelectionForeground": "#7CB342",
            "list.highlightForeground": "#7CB342",
            "list.inactiveSelectionForeground": "#7CB342",
            "menu.selectionForeground": "#7CB342",
            "menubar.selectionForeground": "#7CB342",
            "notificationLink.foreground": "#7CB342",
            "panelTitle.activeBorder": "#7CB342",
            "pickerGroup.foreground": "#7CB342",
            "progressBar.background": "#7CB342",
            "scrollbarSlider.activeBackground": "#7CB34250",
            "selection.background": "#7CB34240",
            "settings.headerForeground": "#7CB342",
            "settings.modifiedItemIndicator": "#7CB342",
            "statusBarItem.remoteBackground": "#7CB342",
            "tab.activeBorder": "#7CB342",
            "textLink.foreground": "#7CB342",
        },
        "statusBar.background": "#181818",
        "statusBar.debuggingBackground": "#181818",
        "statusBar.foreground": "#8beeff",
        "statusBar.noFolderBackground": "#181818",
    },
    "workbench.colorTheme": "Everforest Pro Dark",
    "workbench.editor.useModal": "some",
    "workbench.iconTheme": "vscode-icons",
    "workbench.settings.editor": "json",
}
